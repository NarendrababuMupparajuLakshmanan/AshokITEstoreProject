@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using EStoreAdminModel.Models.Products;
@model IEnumerable<ProductModel>;
<html>
<head>
    <link href="~/bootstrap/css/bootstrap.css" rel="stylesheet" />
</head>
<body>
    <div class="container">
        <div class="row">
            <div class="h1 text-center">
                List of Products
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-sm-3 col-md-3 col-lg-3">
                <a class="btn btn-outline-primary"
                   asp-controller="Product"
                   asp-action="CreateProduct">
                    Create Product
                </a>
            </div>
        </div>

        <div class="row mt-3">
            <table class="table table-primary table-hover table-striped">
                <tr>
                    <td>Product ID</td>
                    <td>Product Name</td>
                    <td>Product Description</td>
                    <td> Brand</td>
                    <td> Type</td>
                    <td> Image</td>
                    <td> Cost</td>
                    <td>GST</td>
                    <td> Total Cost</td>
                    <td>Edit</td>
                    <td>Delete</td>
                </tr>

                @if (Model.Count() == 0)
                {
                    <tr>
                        <td colspan="11">
                            <div class="text-center text-bg-danger">
                                No Products Found
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (ProductModel product in Model)
                    {
                        <tr>
                            <td>@product.Id</td>
                            <td>@product.ProductName</td>
                            <td>@product.ProductDescription</td>
                            <td>@product.BrandId</td>
                            <td>@product.TypeId</td>
                            <td>@product.ImageUrl</td>
                            <td>@product.ProductCost</td>
                            <td>@product.GST</td>
                            <td>@product.TotalCost</td>
                            <td>
                                <a class="btn btn-outline-primary"
                                   asp-controller="Product"
                                   asp-action="EditProduct"
                                   asp-route-id="@product.Id">
                                    Edit
                                </a>
                            </td>
                            <td>
                                <a class="btn btn-outline-danger"
                                   asp-controller="Product"
                                   asp-action="DeleteProduct"
                                   asp-route-id="@product.Id">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
            </table>
        </div>
    </div>
</body>
</html>