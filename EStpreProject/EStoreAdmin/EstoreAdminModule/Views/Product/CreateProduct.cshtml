@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using EStoreAdminModel.Models.Products;
@using EStoreAdminModel.Models.Brands;
@using EStoreAdminModel.Models.Types;
@model CreateProductModel;
<html>
<head>
    <link href="~/bootstrap/css/bootstrap.css" rel="stylesheet" />
</head>
<body>
    @{
            List<BrandModel> brands = ViewBag.Brands;
            List<TypeModel> types = ViewBag.Types;
        }

    <div class="container">
        <div class="col-lg-8 mx-auto rounder border p-3 mt-3">
            <div class="row">
                <div class="h1 text-center">
                    Create Product
                </div>
            </div>
            <form method="post" enctype="multipart/form-data">
                <div class="row mt-3">
                    <div class="col-sm-3 col-md-3 col-lg-3">
                        <label asp-for="ProductName"> Product Name</label>
                    </div>
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <input type="text" asp-for="ProductName" class="form-control" />
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-sm-3 col-md-3 col-lg-3">
                        <label asp-for="ProductDescription"> Product Description</label>
                    </div>
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <textarea  asp-for="ProductDescription" class="form-control" >
                            </textarea>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-sm-3 col-md-3 col-lg-3">
                        <label asp-for="BrandId"> Brand Name</label>
                    </div>
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <select class="form-control" asp-for="BrandId" >
                            <option value="0">--Select Brand--</option>
                                @foreach (BrandModel brand in brands)
                                    {
                                        <option value="@brand.Id">@brand.Name</option>
                                    }
                                </select>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-sm-3 col-md-3 col-lg-3">
                        <label asp-for="TypeId"> Type Name</label>
                    </div>
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <select class="form-control" asp-for="TypeId">
                            <option value="0">--Select Type--</option>
                            @foreach (TypeModel type in types)
                            {
                                <option value="@type.Id">@type.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-sm-3 col-md-3 col-lg-3">
                        <label asp-for="UploadImage">Upload Image</label>
                    </div>
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <input type="file" asp-for="UploadImage" class="form-control"/>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-sm-3 col-md-3 col-lg-3">
                        <label asp-for="ProductCost">Product Cost</label>
                    </div>
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <input type="number" asp-for="ProductCost" class="form-control" />
                    </div>
                </div>


                <div class="row mt-3">
                    <div class="col-sm-6">
                        <a class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                    <div class="col-sm-6">
                        <button class="btn btn-outline-primary"
                                asp-controller="Brand"
                                asp-action="Create">
                            Submit
                        </button>
                    </div>
                </div>
            </form>

        </div>
    </div>
</body>
</html>