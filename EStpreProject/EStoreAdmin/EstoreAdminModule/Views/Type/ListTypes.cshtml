@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using EStoreAdminModel.Models.Types;
@model IEnumerable<TypeModel>;

<html>
<head>
    <link href="~/bootstrap/css/bootstrap.css" rel="stylesheet" />
</head>
<body>

    <div class="container mt-4">
        <div class="row">
            <div class="h1 text-bg-primary text-center">
                Type Details
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-sm-3 col-md-3 col-lg-3">
                <a class="btn btn-outline-primary"
                   asp-controller="Type"
                   asp-action="CreateType">
                    Create Type
                </a>
            </div>
        </div>

        <div class="row mt-3">
            <table class="table table-primary table-hover table-striped">
                <tr>
                    <td>Type ID</td>
                    <td>Type Name</td>
                    <td>Edit</td>
                    <td>Delete</td>
                </tr>

                @if (Model.Count() == 0)
                {
                    <tr>
                        <td colspan="4">
                            <div class="text-center text-bg-danger">
                                No Types Found
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (TypeModel types in Model)
                    {
                        <tr>
                            <td>@types.Id</td>
                            <td>@types.Name</td>
                            <td>
                                <a class="btn btn-outline-primary"
                                   asp-controller="Type"
                                   asp-action="EditType"
                                   asp-route-id="@types.Id">
                                    Edit
                                </a>
                            </td>
                            <td>
                                <a class="btn btn-outline-danger"
                                   asp-controller="Type"
                                   asp-action="DeleteType"
                                   asp-route-id="@types.Id">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
            </table>
        </div>
    </div>
</body>
</html>
