@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using EStoreAdminModel.Models;
@model IEnumerable<BrandModel>;

<html>
<head>

    <link href="~/bootstrap/css/bootstrap.css" rel="stylesheet" />
</head>
<body>

    <div class="container mt-4">
        <div class="row">
            <div class="h1 text-bg-primary text-center">
                Brand Details
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-sm-3 col-md-3 col-lg-3">
                <a class="btn btn-outline-primary"
                    asp-controller="Brand"
                    asp-action="Create">
                    Create Brand
                </a>
            </div>
        </div>
    
        <div class="row mt-3">
            <table class="table table-primary table-hover table-striped">
                <tr>
                    <td>Brand ID</td>
                    <td>Brand Name</td>
                    <td>Edit</td>
                    <td>Delete</td>
                </tr>
                @foreach (BrandModel brands in Model)
                {
                    <tr>
                        <td>@brands.Id</td>
                        <td>@brands.Name</td>
                        <td>
                            <a class="btn btn-outline-primary"
                                asp-controller="Brand"
                               asp-action="EditBrand"
                                asp-route-id="@brands.Id">
                                Edit
                            </a>
                        </td>
                        <td>
                            <a class="btn btn-outline-danger"
                                asp-controller="Brand"
                                asp-action="Delete"
                                asp-route-id="@brands.Id">
                                Delete
                            </a>
                        </td>
                    </tr>
                }

            </table>
        </div>
    </div>
</body>
</html>
